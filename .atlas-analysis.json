  "keyFeatures": [
    "Bun workspace monorepo with three production-ready applications",
    "React 19 SPA with TanStack Router and Query",
    "Next.js 16 full-stack app with Server Components and Better Auth",
    "Expo 53 React Native mobile app with Tamagui",
    "Shared core package with hooks, utilities, and business logic",
    "OpenTelemetry observability integration",
    "Comprehensive E2E testing with Playwright and Maestro",
    "TypeScript-first with strict type checking"
  ],
  "publicApiSurface": [
    "@workspace/spa - React 19 Single Page Application",
    "@workspace/web - Next.js 16 Full-Stack Application",
    "@workspace/expo - Expo 53 React Native Mobile App",
    "@workspace/core - Shared isomorphic package",
    "@workspace/typescript-config - Shared TypeScript configurations",
    "useColorMode - Color mode management hook",
    "useLocalStorageState - Local storage state hook",
    "useSessionStorageState - Session storage state hook",
    "useCopyToClipboard - Copy to clipboard hook",
    "useMediaQuery - Media query hook",
    "useDynamicList - Dynamic list management hook",
    "useHistoryTravel - History travel hook for undo/redo",
    "date utilities - Date formatting and manipulation",
    "logger - Logging utilities",
    "invariant - Runtime assertions"
  ]
